<?xml version="1.0" encoding="UTF-8"?>
<configuration status="warn" monitorInterval="1800">

    <Appenders>
        <Console name="console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{ISO8601} %-5p %logger{1.} - %msg%n" />
        </Console>

    </Appenders>
    
    <loggers>
        <root level="trace">
            <appender-ref ref="console" />
        </root>
    </loggers>
</configuration>